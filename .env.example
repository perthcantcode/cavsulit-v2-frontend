# ─── BACKEND URL ─────────────────────────────────────────────────────────────
# Production (Render):
VITE_API_URL=https://cavsulit-v2-api.onrender.com/api
# Local dev:
# VITE_API_URL=http://localhost:5000/api

# ─── FIREBASE ────────────────────────────────────────────────────────────────
# Get these from: Firebase Console → Project Settings → Your Apps → Web App
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=cavsulit-v2.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=cavsulit-v2
VITE_FIREBASE_STORAGE_BUCKET=cavsulit-v2.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
